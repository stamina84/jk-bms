# Shared configuration for the jk-bms / inverter systemd collectors.
#
# install.sh copies this to /etc/jk-bms/collector.env if it does not exist.
# Both services read it via `EnvironmentFile=-/etc/jk-bms/collector.env`.
# No quotes, no inline comments on value lines (systemd EnvironmentFile rules).

# MQTT broker that Telegraf consumes from (the inverter collector publishes here).
# install.sh fills this in (from the MQTT_BROKER env var or an interactive prompt).
MQTT_BROKER=__MQTT_BROKER__

# mpp-solar protocol used to talk to the inverters over serial.
# Production uses PI30. PI30MAX is also valid for some Easun units.
PROTOCOL=PI30

# JK-BMS batteries: space-separated "MAC=name[=protocol]" entries. Each is read
# over BLE, sequentially, and published to MQTT topic battery/<name>. The third
# field is optional and overrides the protocol for that battery; omit it to use
# JKBMS_PROTOCOL below. install.sh fills this in (from the JKBMS env var or an
# interactive prompt). Example of a mixed-firmware two-pack setup:
#   JKBMS=AA:BB:CC:DD:EE:01=JKBMS1 AA:BB:CC:DD:EE:02=JKBMS2=JK02
JKBMS=__JKBMS__

# Default jkbms protocol for entries that don't specify one.
# Production uses JK02_32 (newer firmware); older packs use JK02.
JKBMS_PROTOCOL=JK02_32

# Sampling interval in seconds = the full cycle target per device. This matches
# the original behaviour (cron every minute + a double read with sleep ~30s,
# i.e. roughly 2 samples/min). The collector measures each read and only sleeps
# for the remainder, so the real cadence is max(read_time, INTERVAL) and reads
# never overlap. Keep INTERVAL >= your measured read time (see deploy/README.md).
INTERVAL=30

# Inverter detection table: space-separated "power:name" pairs. The collector
# reads AC output active power from the inverter and maps it to a name (used as
# the MQTT topic suffix: inverter/<name>). Add a pair per inverter model.
INVERTER_MAP=2400:easun 3000:sp24

# Optional: force a specific port to a known inverter and skip auto-detection.
# Variable name is INVERTER_<port>. Uncomment/adjust as needed:
#INVERTER_ttyUSB0=easun
#INVERTER_ttyUSB1=sp24

# PATH for the service environment. mpp-solar / jkbms are usually installed by
# `pip install` into /usr/local/bin (system) or ~/.local/bin (user). Adjust if
# `which mpp-solar` on the box shows a different location.
PATH=/usr/local/bin:/usr/bin:/bin
